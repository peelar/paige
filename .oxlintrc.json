{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "react",
    "vitest",
    "jsx-a11y",
    "nextjs",
    "promise",
    "node"
  ],
  "settings": {
    "next": {
      "rootDir": "apps/web/"
    }
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "jsx-a11y/prefer-tag-over-role": "off",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "**/.eve/**",
    "**/.next/**",
    "**/.output/**",
    "**/.turbo/**",
    "**/.vercel/**",
    "**/.workflow-data/**",
    "**/node_modules/**",
    "**/playwright-report/**",
    "**/test-results/**"
  ]
}
