{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "rules": {
    "exports": "error",
    "types": "error",
    "nsExports": "error",
    "nsTypes": "error"
  },
  "workspaces": {
    "apps/agent": {
      "ignoreDependencies": ["drizzle-kit"],
      "entry": [
        "agent/channels/*.ts",
        "agent/instructions/*.ts",
        "agent/tools/*.ts",
        "evals/**/*.ts",
        "tests/**/*.ts"
      ]
    }
  }
}
