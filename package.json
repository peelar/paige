{
  "name": "docs-agent-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "brand:check": "node scripts/check-brand-name.mjs",
    "build": "turbo run build",
    "check": "pnpm validation-graph:check && turbo run check && pnpm brand:check && pnpm monorepo:smoke && pnpm status:smoke",
    "db:generate": "pnpm --filter @docs-agent/control-plane db:generate",
    "db:migrate": "pnpm --filter @docs-agent/control-plane db:migrate",
    "dev": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 portless",
    "dev:agent": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 pnpm --filter docs-agent exec portless run --name agent.paige pnpm dev",
    "dev:web": "PORTLESS_PORT=1355 PORTLESS_HTTPS=0 pnpm --filter @docs-agent/web exec portless run --name paige pnpm dev:portless",
    "eval": "pnpm --filter docs-agent eval",
    "monorepo:smoke": "node scripts/check-monorepo.mjs",
    "paige": "pnpm --filter @docs-agent/control-plane paige",
    "prune:local": "pnpm --filter @docs-agent/control-plane prune:local",
    "status:smoke": "node scripts/check-status-smoke.mjs",
    "start": "pnpm --filter docs-agent start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "validation-graph:check": "node scripts/check-validation-graph.mjs"
  },
  "devDependencies": {
    "portless": "0.15.1",
    "turbo": "2.10.5"
  },
  "engines": {
    "node": "24.18.0"
  }
}
