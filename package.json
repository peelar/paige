{
  "name": "paige-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm lint && pnpm knip && turbo run typecheck test --affected",
    "check:full": "pnpm lint && pnpm knip && turbo run typecheck test build",
    "db:studio": "pnpm --filter paige db:studio",
    "db:generate": "pnpm --filter paige db:generate",
    "db:migrate": "pnpm --filter paige db:migrate",
    "dev": "PAIGE_OPERATOR_ACCESS=local PORTLESS_PORT=${PORTLESS_PORT:-1355} PORTLESS_HTTPS=${PORTLESS_HTTPS:-0} node node_modules/portless/dist/cli.js",
    "dev:agent": "PORTLESS_PORT=${PORTLESS_PORT:-1355} PORTLESS_HTTPS=${PORTLESS_HTTPS:-0} pnpm --filter paige exec portless run --name agent.paige pnpm dev",
    "dev:inspect": "pnpm --filter paige dev:inspect",
    "dev:slack-preview": "pnpm --filter paige dev:slack-preview",
    "dev:web": "PORTLESS_PORT=${PORTLESS_PORT:-1355} PORTLESS_HTTPS=${PORTLESS_HTTPS:-0} pnpm --filter @paige/web exec portless run --name paige pnpm dev:portless",
    "eval": "pnpm --filter paige eval",
    "eval:benchmark": "pnpm --filter paige eval:benchmark",
    "eval:behavior": "pnpm --filter paige eval:run behavior",
    "eval:safety": "pnpm --filter paige eval:run safety",
    "eval:integration": "pnpm --filter paige eval:run integration",
    "eval:full": "pnpm --filter paige eval:run full",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "knip": "knip",
    "start": "pnpm --filter paige start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "knip": "^6.26.0",
    "oxlint": "1.73.0",
    "portless": "0.15.1",
    "turbo": "2.10.5"
  },
  "engines": {
    "node": "24.18.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
