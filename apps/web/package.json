    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@typescript/native": "npm:typescript@7.0.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.x",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "^1.4.0",
