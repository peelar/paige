  "private": true,
  "scripts": {
    "build": "next build",
    "check": "pnpm typecheck",
    "dev": "DOCS_AGENT_OPERATOR_ACCESS=local next dev --hostname 127.0.0.1",
    "dev:portless": "DOCS_AGENT_EVE_URL=$(portless get agent.paige) pnpm dev",
