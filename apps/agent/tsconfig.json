{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "agent/**/*.ts",
    "evals/**/*.ts",
    "repositories/**/*.ts",
    ".eve/**/*.d.ts"
  ]
}
