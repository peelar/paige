{
  "name": "docs-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "pnpm --filter @docs-agent/control-plane db:migrate:deployment && eve build",
    "capability:check": "eve info --json >/dev/null && node ../../scripts/check-capability-inventory.mjs",
    "check": "pnpm typecheck && pnpm test",
    "dev": "pnpm --filter @docs-agent/control-plane db:migrate && eve dev",
    "dev:portless": "pnpm dev",
    "eval": "eve eval",
    "start": "pnpm --filter @docs-agent/control-plane db:migrate && eve start",
    "test:run-index:integration": "tsx scripts/check-product-run-integration.ts",
    "test:approval-integration": "tsx scripts/check-approval-integration.ts",
    "test:validation-reporter-integration": "tsx scripts/check-validation-reporter-integration.ts",
    "test": "vitest run --dir tests --pool=forks --maxWorkers=4 --testTimeout=30000",
    "test:watch": "vitest --dir tests --pool=forks --maxWorkers=4 --testTimeout=30000",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@chat-adapter/slack": "4.34.0",
    "@docs-agent/control-plane": "workspace:*",
    "@vercel/connect": "0.3.2",
    "ai": "^7.0.23",
    "chat": "4.34.0",
    "eve": "^0.23.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "drizzle-orm": "^0.45.2",
    "microsandbox": "0.5.7",
    "tsx": "^4.23.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": "24.18.0"
  }
}
