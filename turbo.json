{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".eve/**", ".next/**", "!.next/cache/**", ".output/**"]
    },
    "paige#build": {
      "env": ["PAIGE_SLACK_CONNECTOR", "EVE_GATEWAY_MODEL"],
      "outputs": [".eve/**", ".vercel/output/**", ".output/**"]
    },
    "check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "env": [
        "PAIGE_DATABASE_AUTH_TOKEN",
        "PAIGE_DATABASE_URL",
        "PAIGE_OPERATOR_ACCESS"
      ],
      "persistent": true
    },
    "dev:portless": {
      "cache": false,
      "env": [
        "PAIGE_DATABASE_AUTH_TOKEN",
        "PAIGE_DATABASE_URL",
        "PAIGE_OPERATOR_ACCESS"
      ],
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
