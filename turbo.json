{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "outputs": [
        ".eve/**",
        ".next/**",
        "!.next/cache/**",
        ".output/**"
      ]
    },
    "check": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false
    },
    "typecheck": {
      "outputs": []
    }
  }
}
