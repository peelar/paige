{
  "name": "@docs-agent/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./agent": "./src/agent.ts",
    "./behavior-contract": "./src/behavior-settings-contract.ts",
    "./github": "./src/github-app-client.ts",
    "./github-preflight": "./src/github-preflight.ts",
    "./provider-config": "./src/provider-config.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "build": "pnpm typecheck",
    "check": "pnpm typecheck && pnpm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate-db.ts",
    "db:migrate:deployment": "tsx scripts/migrate-db-for-build.ts",
    "paige": "tsx scripts/setup.ts",
    "prune:local": "tsx scripts/prune-local-state.ts",
    "test": "vitest run --dir tests --pool=forks --maxWorkers=4 --testTimeout=30000",
    "test:watch": "vitest --dir tests --pool=forks --maxWorkers=4 --testTimeout=30000",
    "test:chat-state:remote": "tsx scripts/smoke-libsql-chat-state-remote.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@vercel/connect": "0.3.2",
    "@vercel/oidc": "3.8.0",
    "chat": "4.34.0",
    "drizzle-orm": "^0.45.2",
    "server-only": "^0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": "24.18.0"
  }
}
